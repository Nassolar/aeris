{
  "permissions": {
    "allow": [
      "Read(//z/platform/**)",
      "Read(//z/platform/_shared/firestore/**)",
      "Bash(powershell.exe -ExecutionPolicy Bypass -File deploy-rules.ps1 -SkipConfirm)",
      "Bash(cat .env)",
      "Bash(cat .env.local)"
    ],
    "additionalDirectories": [
      "z:\\platform\\_shared\\firestore"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat .claude/context.md 2>/dev/null || echo 'No context.md — run aeris-start.sh'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys; d=json.load(sys.stdin); p=d.get('tool_input',{}).get('file_path',''); blocked=['.env','firebase.json','.git/']; match=[x for x in blocked if x in p]; sys.stderr.write('BLOCKED: ' + p + ' is protected\\n') if match else None; sys.exit(2 if match else 0)\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo $CLAUDE_TOOL_INPUT | python3 -c \"import json,sys; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('file_path',''))\" 2>/dev/null); if [[ \"$FILE\" == *.ts || \"$FILE\" == *.tsx ]]; then npx prettier --write \"$FILE\" 2>/dev/null; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p docs && echo \"[$(date '+%Y-%m-%d %H:%M')] Session ended\" >> docs/audit-log.txt 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
