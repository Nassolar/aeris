{
  "permissions": {
    "allow": [
      "Read(//z/platform/**)",
      "Read(//z/platform/_shared/firestore/**)",
      "Bash(powershell.exe -ExecutionPolicy Bypass -File deploy-rules.ps1 -SkipConfirm)",
      "Bash(cat .env)",
      "Bash(cat .env.local)",
      "Bash(git add *)",
      "Bash(git rm *)"
    ],
    "additionalDirectories": [
      "z:\\platform\\_shared\\firestore"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat .claude/context.md 2>/dev/null || echo 'No context.md - run aeris-start.sh'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /z/platform/_shared/hooks/guardian-files.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /z/platform/_shared/hooks/guardian-deps.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /z/platform/_shared/hooks/format-on-save.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /z/platform/_shared/hooks/audit-stop.sh"
          }
        ]
      }
    ]
  }
}
